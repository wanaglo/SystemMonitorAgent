{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AgentSettings": {
    "ApiUrl": "http://localhost:5000/api/metrics",
    "IntervalSeconds": 30,
    "HttpTimeoutSeconds": 10,
    "LogFilePath": "logs\\agent-.log",
    "WatchedProcesses": [ "notepad", "explorer", "devenv" ],
    "RetryQueueMaxSize": 100,
    "RetryMaxAttempts": 8,
    "RetryInitialDelaySeconds": 15,
    "RetryMaxDelaySeconds": 600
  }
}
